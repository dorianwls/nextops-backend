{
   "name": "NextOps Dev - .NET 10",
   "dockerComposeFile": ["../docker-compose.yml"],
   "service": "nextops-api",
   "workspaceFolder": "/workspace",
   "customizations": {
      "vscode": {
         "settings": {
            "omnisharp.useModernNet": true
         },
         "extensions": ["ms-dotnettools.csdevkit", "ms-dotnettools.csharp"]
      }
   },
   "forwardPorts": [5000, 5432]
}
